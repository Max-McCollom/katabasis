{
  "name": "katabasis",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Public showcase site for Katabasis. Fully static, no backend, no live-data integration.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node -e \"require('node:fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "preview": "vite preview",
    "check:allowlist": "sh .githooks/allowlist-check.sh",
    "check:telemetry": "node tools/validate-public-telemetry.mjs",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource/ibm-plex-sans-condensed": "^5.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "gsap": "^3.15.0",
    "howler": "^2.2.4",
    "lenis": "^1.3.0",
    "leva": "^0.10.1",
    "postprocessing": "^6.39.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "three-mesh-bvh": "^0.9.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.0",
    "@vitejs/plugin-react": "^6.0.3",
    "draco3dgltf": "^1.5.7",
    "puppeteer-core": "^25.2.0",
    "vite": "^8.0.0"
  }
}
